<% title "#{_(@group_type.name)}" %>
<div class="container">
  <h1><%= _(@group_type.name) %></h1>
  <div class="panel panel-default">
    <div class="panel-heading">
      <h3 class="panel-title"><%= ("Groups") %></h3>
    </div>
    <div class="panel-body">
      <div class="table-responsive">
        <table class="table sortable-theme-bootstrap" data-sortable>
          <thead>
            <th><%= _("Name") %></th>
            <th><%= _("Elected Representatives") %></th>
          </thead>
          <tbody>
            <% for group in @groups %>
            <tr>
              <td><%= link_to _(group.name), group %></td>
              <td><%= group.current_members.count %></td>
            </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
