<% title _("Groups") %>
<div class="container">
  <h2><%= _("Groups")</h2>
  <% for group_type in @groups %>
  <% unless group_type.groups.count < 1 %>
  <div class="panel panel-default">
    <div class="panel-heading">
      <h3 class="panel-title"><%= link_to _(group_type.name), group_type %></h3>
    </div>
    <div class="panel-body">
      <div class="table-responsive">
        <table class="table sortable-theme-bootstrap" data-sortable>
          <thead>
            <th><%= _("Name") %></th>
            <th><%= _("Elected Representatives") %></th>
          </thead>
          <tbody>
            <% for group in group_type.groups %>
            <tr>
              <td><%= link_to _(group.name), group %></td>
              <td><%= group.current_members.count %></td>
            </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <% end %>
  <% end %>
</div>
