<% title "#{_(@group.name)} | #{_(@group.group_type.name)}" %>
<div class="container" itemscope itemtype="http://schema.org/Organization">
  <div class="row">
    <div class="col-md-2">
      <% if @group.avatar.file? %>
      <img alt="<%= _(@group.name) %>" class="img-responsive img-rounded center-block" src="<%= @group.avatar.url(:small) %>">
      <% end %>
    </div>
    <div class="col-md-10">
      <div class="row">
        <div class="col-md-12">
          <h1 itemprop="name"><%= _(@group.name) %></h1>
          <p class="lead">
            <%= _(@group.group_type.name) %>
          </p>
        </div>
      </div>
    </div>
  </div>
  <% if @group.has_contact_details? %>
  <div class="row">
    <div class="col-md-2"></div>
    <div class="col-md-10">
      <%= render partial: "shared/contact_details_box", locals: {subject: @group} %>
    </div>
  </div>
  <% end %>
  <% if @group.description && @group.description.length > 0 %>
  <div class="row">
    <div class="col-md-2"></div>
    <div class="col-md-10">
      <div class="panel panel-default">
        <div class="panel-heading">
          <h3 class="panel-title"><%= _("About") %></h3>
        </div>
        <div class="panel-body">
          <p>
            <%= _(@group.description) %>
          </p>
        </div>
      </div>
    </div>
  </div>
  <% end %>
  <% if @group.current_members.length > 0 %>
  <div class="row">
    <div class="col-md-2"></div>
    <div class="col-md-10">
      <div class="panel panel-default">
        <div class="panel-heading">
          <h3 class="panel-title"><%= _("Current Members") %>
            <span class="text-muted pull-right small"><%= render partial: "shared/report_a_problem_link", locals: { report_subject: @group.name, report_url: request.original_url }%></span>
          </h3>
        </div>
        <div class="panel-body">
          <div class="table-responsive">
            <table class="table sortable-theme-bootstrap" data-sortable>
              <thead>
                <th><%= _('Name') %></th>
                <th><%= _('Position') %></th>
                <th><%= _('From') %></th>
                <th><%= _('To') %></th>
              </thead>
              <tbody>
                <% for member in @group.current_members %>
                <tr>
                  <td><%= link_to _(member.person.fullname), member.person %></td>
                  <td><%= member.person.current_position ? _(member.person.current_position.position_type.title) : "" %></td>
                  <td><%= member.start_date ? _(member.start_date) : _("Unknown") %></td>
                  <td><%= member.end_date ? _(member.end_date) : _("Current") %></td>
                </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
  <% end %>
  <% if @group.former_members.length > 0 %>
  <div class="row">
    <div class="col-md-2"></div>
    <div class="col-md-10">
      <div class="panel panel-default">
        <div class="panel-heading">
          <h3 class="panel-title">Former Members</h3>
        </div>
        <div class="panel-body">
          <div class="table-responsive">
            <table class="table sortable-theme-bootstrap" data-sortable>
              <thead>
                <th><%= _('Name') %></th>
                <th><%= _('Position') %></th>
                <th><%= _('From') %></th>
                <th><%= _('To') %></th>
              </thead>
              <tbody>
                <% for member in @group.former_members %>
                <tr>
                  <td><%= link_to _(member.person.fullname), member.person %></td>
                  <td><%= member.person.current_position ? _(member.person.current_position.position_type.title) : "" %></td>
                  <td><%= member.start_date ? _(member.start_date) : _("Unknown") %></td>
                  <td><%= member.end_date ? _(member.end_date) : _("Current") %></td>
                </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
  <% end %>
</div>
