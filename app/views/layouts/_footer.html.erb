<!-- Footer -->
<footer>
  <div class="container">
    <div class="row">
      <div class="col-md-12">
        <hr>
          <ul class="list-inline pull-right">
            <% if I18n.locale == :ga %>
            <li class="text-muted"><%= link_to t('footer.language_switcher'), url_for(locale: 'en') %></li>
            <% else %>
            <li class="text-muted"><%= link_to t('footer.language_switcher'), url_for(locale: 'ga') %></li>
            <% end %>
            <li class="text-muted"><%= link_to t('general.about'), page_path('about-us') %></li>
            <li class="text-muted"><%= link_to t('footer.powered_by'), "https://github.com/colmdoyle/pobal", target: "_blank", onclick: "ga('send', 'event', 'outbound', 'click', 'https://github.com/colmdoyle/pobal');" %></li>
            <li class="text-muted"><%= link_to t('footer.facebook'), "https://facebook.com/whoismytd", target: "_blank", onclick: "ga('send', 'event', 'outbound', 'click', 'https://facebook.com/whoismytd');" %></li>
            <li class="text-muted"><%= link_to t('footer.twitter'), "https://twitter.com/whoismytd", target: "_blank", onclick: "ga('send', 'event', 'outbound', 'click', 'https://twitter.com/whoismytd');" %></li>
          </ul>
      </div>
    </div>
  </div>
</footer>
<!-- /Footer -->
