<% title _("Bodies") %>
<div class="container">
  <h2><%= _("Bodies") %></h2>
  <% for body_type in @bodies %>
  <% unless body_type.bodies.count < 1 %>
  <div class="panel panel-default">
    <div class="panel-heading">
      <h3 class="panel-title"><%= link_to _(body_type.name), body_type %></h3>
    </div>
    <div class="panel-body">
      <div class="table-responsive">
        <table class="table sortable-theme-bootstrap" data-sortable>
          <thead>
            <th><%= _("Name") %></th>
          </thead>
          <tbody>
            <% for body in body_type.bodies %>
            <tr>
              <td><%= link_to _(body.name), body %></td>
            </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <% end %>
  <% end %>
</div>
