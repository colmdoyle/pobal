<% title _("Constituencies") %>
<div class="container">
  <h2><%= _("Constituencies") %></h2>
<% for constituency in @constituencies %>
  <h3><%= link_to _(constituency.name), constituency %> (<%= _(constituency.constituency_type.name) %>)</h3>
<% end %>
<%= will_paginate @constituencies, renderer: BootstrapPagination::Rails %>
</div>
